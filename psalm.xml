<?xml version="1.0"?>
<psalm
    errorLevel="4"
    resolveFromConfigFile="true"
    findUnusedBaselineEntry="true"
    findUnusedCode="false"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns="https://getpsalm.org/schema/config"
    xsi:schemaLocation="https://getpsalm.org/schema/config vendor/vimeo/psalm/config.xsd"
    errorBaseline="psalm-baseline.xml"
>
    <projectFiles>
        <directory name="Analytics"/>
        <directory name="Autocomplete"/>
        <directory name="ProductFeatures"/>
        <directory name="SearchGraphQl"/>
        <ignoreFiles allowMissingFiles="true">
            <directory name="vendor"/>
            <directory name="Analytics/Test"/>
            <directory name="Autocomplete/Test"/>
            <directory name="ProductFeatures/Test"/>
            <directory name="SearchGraphQl/Test"/>
            <file name="Analytics/registration.php"/>
            <file name="Autocomplete/registration.php"/>
            <file name="ProductFeatures/registration.php"/>
            <file name="SearchGraphQl/registration.php"/>
        </ignoreFiles>
    </projectFiles>

    <issueHandlers>
        <PropertyNotSetInConstructor>
            <errorLevel type="suppress">
                <directory name="Analytics"/>
                <directory name="Autocomplete"/>
                <directory name="ProductFeatures"/>
                <directory name="SearchGraphQl"/>
            </errorLevel>
        </PropertyNotSetInConstructor>
    </issueHandlers>
</psalm>
